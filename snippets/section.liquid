{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_position: section.settings.background_image_position
    %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
        {% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}__content{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .about-welcome-layout {
    --about-welcome-panel-radius: 30px;
    --about-welcome-panel-padding: clamp(1.5rem, 1rem + 2vw, 3rem);
    --about-welcome-gap: clamp(1.5rem, 1.2rem + 1vw, 3rem);
  }

  .about-welcome-layout .custom-section-content {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: var(--about-welcome-panel-radius);
    background:
      linear-gradient(180deg, rgb(var(--color-background-rgb)), rgb(var(--color-background-rgb) / 0.96)),
      linear-gradient(135deg, rgb(236 228 218 / 0.55), rgb(255 255 255 / 0));
    box-shadow: 0 18px 44px rgb(var(--color-shadow-rgb) / 0.06);
  }

  .about-welcome-layout .section-content-wrapper {
    gap: var(--about-welcome-gap);
    padding: var(--about-welcome-panel-padding);
    align-items: start;
  }

  .about-welcome-layout .block:first-child {
    min-width: 0;
  }

  .about-welcome-layout .block:last-child {
    min-width: 0;
    color: rgb(var(--color-foreground-rgb) / 0.8);
    line-height: 1.75;
  }

  .about-welcome-layout .block:first-child p:first-child {
    margin: 0 0 0.8rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(110 89 72);
  }

  .about-welcome-layout .block:first-child h2 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2rem, 1.5rem + 2vw, 3.6rem);
    line-height: 0.97;
    letter-spacing: -0.04em;
    color: rgb(var(--color-foreground-rgb) / 0.96);
    text-wrap: balance;
  }

  .about-welcome-layout .block:first-child h2 + p {
    margin-top: 1rem;
    max-width: 28rem;
    color: rgb(var(--color-foreground-rgb) / 0.72);
    line-height: 1.6;
  }

  .about-welcome-layout .block:first-child p:last-child a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    width: fit-content;
    margin-top: 0.25rem;
    padding: 0.8rem 1.15rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    border-radius: 999px;
    background: rgb(var(--color-background-rgb));
    color: rgb(var(--color-foreground-rgb) / 0.9);
    font-weight: 600;
    text-decoration: none;
    transition: transform var(--surface-transition-duration) var(--surface-transition-timing),
      border-color var(--surface-transition-duration) var(--surface-transition-timing),
      box-shadow var(--surface-transition-duration) var(--surface-transition-timing);
  }

  .about-welcome-layout .block:first-child p:last-child a:focus-visible {
    outline: 2px solid currentcolor;
    outline-offset: 3px;
  }

  .about-welcome-layout .block:last-child p + p {
    margin-top: 1.15rem;
  }

  @media (any-pointer: fine) and (prefers-reduced-motion: no-preference) {
    .about-welcome-layout .block:first-child p:last-child a:hover {
      transform: translateY(-1px);
      border-color: rgb(var(--color-foreground-rgb) / 0.22);
      box-shadow: 0 12px 24px rgb(var(--color-shadow-rgb) / 0.08);
    }
  }

  @media screen and (max-width: 749px) {
    .about-welcome-layout {
      --about-welcome-panel-radius: 24px;
      --about-welcome-panel-padding: 1.35rem;
    }
  }
{% endstylesheet %}
