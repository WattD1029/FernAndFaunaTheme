

{% liquid
  assign section_collections = collections
  assign max_items = 20
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    section-resource-list--all-collections
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__content">
    {%- content_for 'blocks' -%}
  </div>

  {% if section_collections == null %}
    {% for i in (1..max_items) %}
      {% assign section_collections = section_collections | append: ', ' %}
    {% endfor %}

    {% assign section_collections = section_collections | split: ',' %}
  {% endif %}

  {% capture list_items %}
    {% for collection in section_collections limit: max_items %}
      <div class="resource-list__item">
        {% content_for 'block', type: '_collection-card', id: 'static-collection-card', closest.collection: collection %}
      </div>
      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}
    {% endfor %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    carousel_ref: 'mainCollectionList',
    slide_count: max_items,
    content_type: 'collections',
    test_id: 'collections-list-grid'
  %}
</div>

{% stylesheet %}
  .section-resource-list--all-collections {
    --all-collections-card-radius: 28px;
    --all-collections-card-padding: clamp(0.95rem, 1.8vw, 1.2rem);
    --all-collections-card-border: rgb(var(--color-border-rgb) / 0.18);
    --all-collections-card-shadow: 0 14px 32px rgb(var(--color-shadow-rgb) / var(--opacity-10));
    --all-collections-card-shadow-hover: 0 24px 54px rgb(var(--color-shadow-rgb) / 0.14);
  }

  .section-resource-list--all-collections .resource-list__item {
    height: 100%;
  }

  .section-resource-list--all-collections .collection-card {
    height: 100%;
  }

  .section-resource-list--all-collections .collection-card__inner {
    height: 100%;
    border: 1px solid var(--all-collections-card-border);
    border-radius: var(--all-collections-card-radius);
    background: rgb(var(--color-background-rgb));
    box-shadow: var(--all-collections-card-shadow);
    transition: transform var(--surface-transition-duration) var(--surface-transition-timing),
      border-color var(--surface-transition-duration) var(--surface-transition-timing),
      box-shadow var(--surface-transition-duration) var(--surface-transition-timing),
      background-color var(--surface-transition-duration) var(--surface-transition-timing);
  }

  .section-resource-list--all-collections .collection-card__link {
    border-radius: var(--all-collections-card-radius);
  }

  .section-resource-list--all-collections .collection-card__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    min-height: calc(var(--minimum-touch-target) + 0.6rem);
    padding: var(--all-collections-card-padding);
    background: linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.96), rgb(var(--color-background-rgb)));
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .section-resource-list--all-collections .collection-card__content::after {
    content: '>';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: var(--minimum-touch-target);
    height: var(--minimum-touch-target);
    border-radius: 999px;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    color: rgb(var(--color-foreground-rgb) / 0.82);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    transition: transform var(--surface-transition-duration) var(--surface-transition-timing),
      background-color var(--surface-transition-duration) var(--surface-transition-timing),
      color var(--surface-transition-duration) var(--surface-transition-timing);
  }

  .section-resource-list--all-collections .collection-card__content > * {
    min-width: 0;
  }

  .section-resource-list--all-collections .collection-card__content p {
    margin: 0;
    font-weight: 600;
    line-height: 1.35;
    color: rgb(var(--color-foreground-rgb) / 0.94);
  }

  .section-resource-list--all-collections .collection-card__image,
  .section-resource-list--all-collections .collection-card__image .image-block,
  .section-resource-list--all-collections .collection-card__image .image-block__image,
  .section-resource-list--all-collections .collection-card__image .placeholder-svg {
    border-radius: calc(var(--all-collections-card-radius) - 1px) calc(var(--all-collections-card-radius) - 1px) 0 0;
  }

  .section-resource-list--all-collections .collection-card__link:focus-visible + .collection-card__inner {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
    border-color: rgb(var(--color-foreground-rgb) / 0.22);
  }

  @media (any-pointer: fine) and (prefers-reduced-motion: no-preference) {
    .section-resource-list--all-collections .collection-card:hover .collection-card__inner,
    .section-resource-list--all-collections .collection-card:focus-within .collection-card__inner {
      transform: translateY(-6px);
      border-color: rgb(var(--color-foreground-rgb) / 0.22);
      box-shadow: var(--all-collections-card-shadow-hover);
    }

    .section-resource-list--all-collections .collection-card:hover .collection-card__content::after,
    .section-resource-list--all-collections .collection-card:focus-within .collection-card__content::after {
      transform: translateX(2px);
      background: rgb(var(--color-foreground-rgb));
      color: rgb(var(--color-background-rgb));
    }
  }

  @media screen and (max-width: 749px) {
    .section-resource-list--all-collections {
      --all-collections-card-radius: 22px;
      --all-collections-card-padding: 0.9rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.collection_list",
  "class": "ui-test-collection-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.cards_layout"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "bento",
          "label": "t:options.bento"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "bento_gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'bento' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "range",
      "id": "max_collections",
      "label": "t:settings.collection_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type == 'editorial' }}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
